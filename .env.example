# Supabase: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Cloudflare R2: bucket S3 API credentials (server only)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shackmenu

# Runtime
PORT=3000
PUBLIC_APP_URL=http://localhost:8788

# Stripe Billing (server only except the publishable key)
STRIPE_PUB=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# Required by the Stripe webhook to update subscriptions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare for SaaS (server only)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_SAAS_ZONE_ID=
CLOUDFLARE_SAAS_CNAME_TARGET=proxy-fallback.shackmenu.com

# Cloudflare Email Service (server only)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=

# Supabase Edge Function email bridge (server only)
SHACKMENU_EMAIL_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Shack Menu <support@shackmenu.com>"

# Mercado Pago marketplace/orders (server only except public keys)
MP_PUBLIC=
MP_TOKEN=
MP_PUBLIC_PROD=
MP_TOKEN_PROD=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_CHECKOUT_TEST_MODE=false
ORDER_PLATFORM_FEE_PERCENT=15

# Comma-separated Supabase user UUIDs allowed to access /api/admin/*
ADMIN_USER_IDS=
